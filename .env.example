# Скопируйте в .env и задайте свои значения для прод-запуска (docker-compose.prod.yml).

# Пароль пользователя БД (одинаков для Postgres и строки подключения API).
DB_PASSWORD=wmess

# Секрет подписи JWT — минимум 32 символа. ОБЯЗАТЕЛЬНО замените в продакшене.
JWT_SECRET=ChangeThisProductionJwtSecret_MinimumOf32Chars

# Доменное имя для nginx / CN сертификата. Для локального теста — localhost.
SERVER_NAME=localhost

# Внешние порты nginx. HTTP только редиректит на HTTPS.
HTTP_PORT=80
HTTPS_PORT=443
